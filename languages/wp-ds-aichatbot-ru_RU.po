msgstr "Заявки WP DS AI Chatbot"

msgid "WP DS AI Chatbot conversations"
msgstr "Диалоги WP DS AI Chatbot"

msgid "WP DS AI Chatbot requires Elementor %s or newer for its Elementor widget."
msgstr "Для виджета WP DS AI Chatbot требуется Elementor %s или новее."

msgid "WP DS AI Chatbot requires PHP 7.4 or newer."
msgstr "Для WP DS AI Chatbot требуется PHP 7.4 или новее."

msgid "Website"
msgstr "Сайт"

msgid "Welcome message"
msgstr "Приветственное сообщение"

msgid "When contact collection is enabled, the chatbot stores the submitted name, email address, the consent text shown at submission, and the submission time for the configured retention period. IP addresses and raw chat session identifiers are not stored. Contact requests can be exported or erased using the WordPress privacy tools."
msgstr "Когда сбор контактов включён, чатбот хранит имя, email, текст согласия и время отправки в течение заданного срока. IP-адреса и исходные идентификаторы сессий не сохраняются. Заявки можно экспортировать или удалить инструментами приватности WordPress."

msgid "When conversation logging is enabled, chatbot messages are stored for the configured retention period. Session identifiers are stored only as one-way hashes. Logs associated with authenticated WordPress users can be exported or erased using the WordPress privacy tools. Anonymous logs cannot be linked back to an email address."
msgstr "Когда журнал диалогов включён, сообщения хранятся в течение заданного срока. Идентификаторы сессий сохраняются только как необратимые хэши. Диалоги авторизованных пользователей можно экспортировать или удалить инструментами приватности WordPress. Анонимные диалоги нельзя связать с email."

msgid "WordPress AI Client (WordPress 7.0+)"
msgstr "AI-клиент WordPress (WordPress 7.0+)"

msgid "WordPress AI Client requires WordPress 7.0 or newer and a configured connector."
msgstr "Для AI-клиента требуется WordPress 7.0 или новее и настроенный коннектор."

msgid "Would you like us to contact you?"
msgstr "Хотите, чтобы мы связались с вами?"

msgid "You are a concise and helpful website support assistant. Reply in the same language as the visitor."
msgstr "Вы — полезный консультант сайта. Отвечайте кратко и на языке посетителя."

msgid "You are not allowed to manage PDF knowledge sources."
msgstr "У вас нет прав для управления PDF-источниками знаний."

msgid "You are not allowed to manage the knowledge index."
msgstr "У вас нет прав для управления индексом знаний."

msgid "You are not allowed to change these settings."
msgstr "У вас нет прав для изменения этих настроек."

msgid "Provider diagnostics"
msgstr "Диагностика провайдера"

msgid "No API key value is exposed. For console diagnostics run wpdsacDebugProvider()."
msgstr "Значение API-ключа не выводится. Для диагностики в консоли выполните wpdsacDebugProvider()."

msgid "Credential source"
msgstr "Источник ключа"

msgid "Configured"
msgstr "Настроен"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Нет"

msgid "Settings were saved, but the selected provider still has no API key. Open the browser console and run wpdsacDebugProvider()."
msgstr "Настройки сохранены, но у выбранного провайдера всё ещё нет API-ключа. Откройте консоль браузера и выполните wpdsacDebugProvider()."

msgid "Prompt injection protection"
msgstr "Защита от промпт-инъекций"

msgid "Allowed topics and keywords"
msgstr "Разрешённые темы и ключевые слова"

msgid "Blocked request response"
msgstr "Ответ на заблокированный запрос"

msgid "I can only help with questions related to this website."
msgstr "Я могу помочь только с вопросами, относящимися к этому сайту."

msgid "Block obvious instruction overrides, hidden-prompt requests, model probing, and configured off-topic requests before contacting the AI provider."
msgstr "Блокировать попытки подменить инструкции, запросы скрытого промпта, вопросы о модели и настроенные вопросы не по теме до обращения к AI-провайдеру."

msgid "Describe this website and list allowed topics or keywords. When filled, unrelated questions are blocked before the AI request."
msgstr "Опишите сайт и перечислите разрешённые темы или ключевые слова. После заполнения вопросы не по теме будут блокироваться до обращения к AI."

msgid "Knowledge entry"
msgstr "Запись базы знаний"

msgid "Add knowledge entry"
msgstr "Добавить запись"

msgid "Edit knowledge entry"
msgstr "Редактировать запись базы знаний"

msgid "New knowledge entry"
msgstr "Новая запись базы знаний"

msgid "Search knowledge entries"
msgstr "Искать в базе знаний"

