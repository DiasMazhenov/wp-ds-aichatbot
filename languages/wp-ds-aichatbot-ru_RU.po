msgid "Use {username} to insert the visitor name, for example: {username}, hello!"
msgstr "Используйте {username}, чтобы вставить имя посетителя. Например: {username}, привет!"
msgid "Use {username} to insert the visitor name. The (username) alias is also supported."
msgstr "Используйте {username}, чтобы вставить имя посетителя. Алиас (username) также поддерживается."

