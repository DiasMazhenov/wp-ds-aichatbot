{
  "name": "diasmazhenov/wp-ds-aichatbot",
  "description": "Extensible AI chatbot plugin for WordPress and Elementor.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4",
    "smalot/pdfparser": "^2.12.5"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "doctrine/instantiator": "^1.5",
    "phpcompatibility/php-compatibility": "^9.3",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpunit/phpunit": "^9.6",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "DiasMazhenov\\WPDsAiChatbot\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "7.4.0"
    },
    "sort-packages": true
  },
  "scripts": {
    "lint": "phpcs -q",
    "format": "phpcbf",
    "test:unit": "phpunit --configuration phpunit.xml.dist"
  }
}
